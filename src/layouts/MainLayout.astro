---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "AI Infrastructure Engineer Portfolio"
} = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />

  <title>{title}</title>

  <meta
    name="description"
    content={description}
  />
</head>

<body>

  <header class="navbar">
    <nav>

      <a href="/" class="brand">
        HAQS
      </a>

      <div class="nav-links">
        <a href="/projects">Projects</a>
        <a href="/blog">Blog</a>
        <a href="/contact">Contact</a>
      </div>

    </nav>
  </header>

  <main>
    <slot />
  </main>

</body>
</html>